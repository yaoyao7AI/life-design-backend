## =========================
## Life Design Backend - 环境变量模板（请勿填入真实密钥后再分享）
## 使用方式：
## - 本地：复制为 .env 并填写真实值
## - 服务器：推荐用系统环境变量或只在服务器上维护 .env
## =========================

## 运行环境
NODE_ENV=development
PORT=3000

## 数据库（MySQL）
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASS=your-mysql-password
DB_NAME=life_design

## JWT
## 生产环境务必更换为强随机值
JWT_SECRET=change_me_in_production
## Access token 有效期（MVP 默认 30 天）
JWT_ACCESS_EXPIRES=30d

## 阿里云短信（可选：本地 NODE_ENV!=production 时短信失败仍返回 200，验证码在内存+控制台；生产未配置会 500）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN=
ALIYUN_SMS_TEMPLATE=

## 对外静态资源根（可选，强烈建议生产配置）
## 上传接口返回的图片 URL 会拼成：{PUBLIC_ASSET_BASE_URL}/uploads/...
## 须为浏览器可访问的 HTTPS 源，且 Nginx 需把该域名下的 /uploads 转到本服务
## 例：PUBLIC_ASSET_BASE_URL=https://api.life-design.me
PUBLIC_ASSET_BASE_URL=

## 安全与行为开关
## 生产建议：显式配置允许的前端域名（逗号分隔）
## 例：CORS_ORIGINS=https://life-design.me,https://www.life-design.me
CORS_ORIGINS=

## 自动建表（默认关闭；仅在需要时开启）
AUTO_MIGRATE_SYNC_SCHEMA=0

## 调试开关
DB_DEBUG=0
